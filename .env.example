# Copia este archivo como ".env" y rellena solo las claves que quieras usar.
# Si dejas LLM_PROVIDER=auto, la aplicacion usara la primera API disponible.

LLM_PROVIDER=auto

# Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenAI / ChatGPT
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google / Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# xAI / Grok
XAI_API_KEY=
XAI_MODEL=grok-4

# Opcional
MCM5_HOST=127.0.0.1
MCM5_PORT=8080
MCM5_WORKSPACE_DIR=
MCM5_DDS_DIR=
MCM5_RDI_DIR=
MCM5_PM_DIR=
MCM5_MIE_DIR=
